{
  "name": "yalla-turbo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@yallasana/web",
    "dev:server": "turbo run dev --filter=@yallasana/server",
    "dev:mobile": "turbo run dev --filter=@yallasana/mobile",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20"
  }
}
